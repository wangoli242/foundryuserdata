<div class="dg-wizard-wrapper" data-step="{{step}}">

    {{!-- Progress bar --}}
    <div class="dg-wizard-progress">
        {{#each (range 0 totalSteps)}}
        <div class="dg-step-dot {{#if (eq this ../stepIndex)}}active{{/if}} {{#if (lt this ../stepIndex)}}done{{/if}} {{#if (lookup ../stepWarnings this)}}has-warning{{/if}}"
            data-step-index="{{this}}" title="{{lookup ../stepTitles this}}">
        </div>
        {{/each}}
        <span class="dg-step-label">Step {{inc stepIndex}} of {{totalSteps}}</span>
    </div>

    <form class="dg-wizard-form" autocomplete="off">

        {{!-- ================================================================
        STEP: welcome
        ================================================================ --}}
        {{#if (eq step "welcome")}}
        <div class="dg-step dg-step-welcome">
            <h2>Welcome, Agent</h2>
            <p class="dg-flavour">
                You've been read in. The Program needs another agent — someone with the skills,
                the bonds, and the will to face what lies beyond. Follow these steps to build
                your character. Nothing you learn here can be unlearned.
            </p>
            <p>
                This wizard will guide you through:<br>
                <strong>Statistics → Profession → Skills → Bonus Skills → Bonds → Biography → Equipment →
                    Review</strong>
            </p>
            <canvas id="dg-welcome-pyramid" aria-hidden="true" class="dg-welcome-pyramid"></canvas>
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: stats
        ================================================================ --}}
        {{#if (eq step "stats")}}
        <div class="dg-step dg-step-stats">
            <h2>Statistics</h2>

            <details class="dg-tips">
                <summary>Tips</summary>
                <p>Your Agent's six core abilities. You have three ways to set them:</p>
                <ul class="dg-tips-list">
                    <li><strong>🔀 Randomize (72 pts)</strong> — Spreads 72 points across all six stats randomly within
                        the point-buy rules.</li>
                    <li><strong>🎲 Roll All (4d6 drop lowest)</strong> — Old-school: rolls 4d6 drop-lowest for each
                        stat.</li>
                    <li><strong>+ / −</strong> — Manual point-buy: use the + and − buttons on each stat card to spend
                        your 72 points exactly as you want.</li>
                </ul>
                <ul class="dg-tips-list">
                    <li><strong>STR</strong> (Strength) — Physical power and size. Break down doors, drag a witness to
                        safety.</li>
                    <li><strong>DEX</strong> (Dexterity) — Agility and coordination. React quickly, keep balance.</li>
                    <li><strong>CON</strong> (Constitution) — Health and resilience. Resist illness, exhaustion, and
                        pain.</li>
                    <li><strong>INT</strong> (Intelligence) — How well your Agent notices, remembers, and connects
                        things.</li>
                    <li><strong>POW</strong> (Power) — Force of personality and psychic resilience. Keep your head in a
                        crisis.</li>
                    <li><strong>CHA</strong> (Charisma) — Charm and personal appeal. Make impressions, talk your way in.
                    </li>
                </ul>
                <p><em>HP = ⌈(STR+CON)÷2⌉ &nbsp;|&nbsp; WP = POW &nbsp;|&nbsp; SAN = POW×5</em></p>
            </details>

            <p class="dg-hint">Distribute 72 points across your six statistics (3–18).</p>

            <div class="dg-points-bar">
                Points remaining: <span
                    class="dg-points-remaining{{#if (eq pointsRemaining 0)}} depleted{{/if}}">{{pointsRemaining}}</span>
                / 72
            </div>

            <div class="dg-stats-grid">
                {{#each stats}}
                <div class="dg-stat-block">
                    <label class="dg-stat-label">{{lookup ../statLabels @key}}</label>
                    <div class="dg-stat-controls">
                        <button type="button" data-action="adjustStat" data-stat="{{@key}}" data-delta="-1"
                            class="dg-adjust-btn">−</button>
                        <input type="number" name="stats.{{@key}}" value="{{this}}" min="3" max="18"
                            class="dg-stat-input" />
                        <button type="button" data-action="adjustStat" data-stat="{{@key}}" data-delta="1"
                            class="dg-adjust-btn">+</button>
                    </div>
                    <span class="dg-x5">×5 = {{multiply this 5}}</span>
                    <span class="dg-descriptor">{{lookup ../statDescriptors @key}}</span>
                </div>
                {{/each}}
            </div>

            <div class="dg-derived-bar">
                <div class="dg-derived-item"><span class="dg-derived-label">HP</span><strong>{{derived.hp}}</strong>
                </div>
                <div class="dg-derived-item"><span class="dg-derived-label">WP</span><strong>{{derived.wp}}</strong>
                </div>
                <div class="dg-derived-item"><span class="dg-derived-label">SAN</span><strong>{{derived.san}}</strong>
                </div>
                <div class="dg-derived-item"><span class="dg-derived-label">BP</span><strong>{{derived.bp}}</strong>
                </div>
            </div>

            <div class="dg-stats-actions">
                <button type="button" data-action="rollStats" class="dg-btn-secondary">🎲 Roll All (4d6 drop
                    lowest)</button>
                <button type="button" data-action="randomizeStats" class="dg-btn-secondary">🔀 Randomize (72
                    pts)</button>
                <button type="button" data-action="resetStats" class="dg-btn-secondary">↺ Reset</button>
            </div>
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: profession
        ================================================================ --}}
        {{#if (eq step "profession")}}
        <div class="dg-step dg-step-profession">
            <h2>Profession</h2>

            <details class="dg-tips">
                <summary>Tips</summary>
                <p>This is your biggest decision. Profession determines your Agent's skills, role in an operation, and
                    sometimes the resources your Agent can bring to bear by requisitioning equipment.</p>
                <p>A handful of core professions are most frequently seen among Agents: Anthropologist or Historian,
                    Computer Scientist or Engineer, Federal Agent, Physician, Scientist, and Special Operator. Many
                    other professions are described in the Agent's Handbook.</p>
                <p>Each profession provides <em>required skills</em> at fixed values and <em>optional skills</em> you
                    may choose from. After you pick your skills, you'll get <strong>8 background bonus skill
                        picks</strong> (+20 each) to customize further.</p>
            </details>

            <p class="dg-hint">Choose the profession that best fits your agent's background.</p>
            <div class="dg-profession-picker">
                <select name="professionKey" class="dg-select-profession">
                    <option value="">— Select a Profession —</option>
                    {{#each professions}}
                    <option value="{{key}}" {{#if (eq key ../professionKey)}}selected{{/if}}>{{title}}</option>
                    {{/each}}
                </select>
            </div>
            <div class="dg-profession-desc" {{#unless profession}}style="display:none" {{/unless}}>
                <pre class="dg-desc-text">{{#if profession}}{{profession.description}}{{/if}}</pre>
            </div>
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: skills
        ================================================================ --}}
        {{#if (eq step "skills")}}
        <div class="dg-step dg-step-skills">
            <h2>Skills</h2>

            <details class="dg-tips">
                <summary>Tips</summary>
                <p>Choose your optional profession skills at the top, then fill in any required specialty names
                    (Foreign Language, Science, Craft, etc.). The full list of automatically assigned skills is
                    shown in the table below for reference.</p>
                <p><strong>Skill Ratings:</strong><br>
                    1–19%: Dabbler &nbsp;|&nbsp; 20–29%: Hobbyist &nbsp;|&nbsp; 30–39%: Basic training or a college
                    minor<br>
                    40–59%: Years of experience or a college major &nbsp;|&nbsp; 60–79%: Decades of experience or a grad
                    degree &nbsp;|&nbsp; 80–99%: A lifetime's mastery
                </p>
                <details class="dg-tips-inner">
                    <summary>Notable Skills</summary>
                    <ul class="dg-tips-list">
                        <li><strong>Craft</strong> — Mastery of a difficult trade such as electronics, carpentry, or
                            plumbing.</li>
                        <li><strong>HUMINT</strong> — Human intelligence: the study and deciphering of behavior and
                            motivations.</li>
                        <li><strong>SIGINT</strong> — Encryption, decryption, and signals intelligence.</li>
                        <li><strong>Unnatural</strong> — Knowledge of Things Man Was Not Meant to Know. This skill
                            cannot be raised during character creation.</li>
                    </ul>
                </details>
            </details>

            {{#if profession}}

            {{!-- Datalists for specialty autocomplete (one per group) --}}
            {{#if specialtyContext}}
            {{#each specialtyContext.dataLists}}
            <datalist id="{{id}}">
                {{#each options}}<option value="{{this}}">{{/each}}
            </datalist>
            {{/each}}
            {{/if}}

            {{!-- SECTION 1: Optional skill picks --}}
            {{#if hasOptionalSkills}}
            <div class="dg-optional-picks-section">
                <div class="dg-opt-section-header">
                    <h3 class="dg-opt-heading">Choose any {{optLimit}} of these:</h3>
                    <span class="dg-opt-picks-counter" data-limit="{{optLimit}}">Optional picks:
                        <strong>{{optPicksUsed}} / {{optLimit}}</strong></span>
                </div>
                {{#each optionalSkillItems}}
                <div class="dg-opt-skill-row" {{#if tooltip}} title="{{tooltip}}" {{/if}}>
                    <label class="dg-opt-label">
                        <input type="checkbox" name="optPick" value="{{optIndex}}" {{#if picked}}checked{{/if}} />
                        <span class="dg-opt-skill-name">{{label}}</span>
                        {{#if isSpecialty}}
                        <input type="text" name="specialty.opt.{{optIndex}}" value="{{specialtyLabel}}"
                            list="dg-sp-{{group}}" placeholder="Choose or type subspecialty"
                            class="dg-specialty-input dg-opt-spec-input" {{#unless picked}}disabled{{/unless}} />
                        {{/if}}
                        <span class="dg-opt-skill-value">{{profValue}}%</span>
                    </label>
                </div>
                {{/each}}
            </div>
            {{/if}}

            {{!-- SECTION 2: Required specialty inputs --}}
            {{#if specialtyContext.required}}
            <div class="dg-specialty-section">
                <h4 class="dg-specialty-heading">Specialty Skills (Required — type or choose)</h4>
                {{#each specialtyContext.required}}
                <div class="dg-specialty-row{{#unless label}} dg-specialty-empty{{/unless}}">
                    <span class="dg-specialty-group">{{groupDisplay}}</span>
                    <input type="text" name="specialty.req.{{id}}" value="{{label}}" list="dg-sp-{{group}}"
                        data-group="{{group}}"
                        placeholder="e.g. {{groupDisplay}} ({{example}}) — choose from list or type your own"
                        class="dg-specialty-input" />
                    <span class="dg-specialty-value">{{proficiency}}%</span>
                </div>
                {{/each}}
            </div>
            {{/if}}

            {{!-- SECTION 3: Required skills table --}}
            <p class="dg-hint">Required skills automatically assigned by this profession:</p>
            <table class="dg-skills-table">
                <thead>
                    <tr>
                        <th>Skill</th>
                        <th>Value</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each skills}}
                    <tr class="dg-skill-required" {{#if tooltip}} title="{{tooltip}}" {{/if}}>
                        <td>{{label}}</td>
                        <td class="dg-num dg-skill-current">{{current}}</td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>

            {{else}}
            <p class="dg-warn">Please go back and select a profession first.</p>
            {{/if}}
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: bonus_skills
        ================================================================ --}}
        {{#if (eq step "bonus_skills")}}
        <div class="dg-step dg-step-bonus-skills">
            <h2>Bonus Skills</h2>

            <details class="dg-tips">
                <summary>Tips</summary>
                <p>What did your Agent do before his or her current profession?</p>
                <p>These 8 bonus skill picks represent that history — hobbies, side training, a past life. Use them to
                    round out your Agent as a person: a Federal Agent who rock-climbs on weekends, a Physician who
                    speaks three languages, a Soldier who paints.</p>
                <p>No skill can go above <strong>80%</strong> during character creation. You may pick the same skill
                    more than once to boost it further (still capped at 80).</p>
                <p>For specialty skills (Art, Craft, Foreign Language, Pilot, Science, Military Science) select the
                    group from the dropdown — a subspecialty text box will appear beside it.
                </p>
            </details>

            {{#if bonusSkills}} {{!-- Datalists for specialty autocomplete --}}
            {{#each bonusSkills.bonusDataLists}}
            <datalist id="{{id}}">{{#each options}}<option value="{{this}}">{{/each}}</datalist>
            {{/each}} <p class="dg-bonus-choice-note">Pick a <strong>background package</strong> to auto-fill your 8
                skill picks —
                or skip it and assign them manually below.</p>
            <div class="dg-bonus-pack-row">
                <label>Background package:
                    <select id="dg-bonus-pack-select">
                        <option value="">— choose a background —</option>
                        {{#each bonusSkills.packages}}
                        <option value="{{@index}}" {{#if (eq @index ../bonusSkills.packIdx)}}selected{{/if}}>{{label}}
                        </option>
                        {{/each}}
                    </select>
                </label>
                <button type="button" data-action="fillPack" class="dg-btn-secondary">Fill Slots</button>
                {{#if bonusSkills.packDesc}}
                <p class="dg-bonus-pack-desc">{{bonusSkills.packDesc}}</p>
                {{/if}}
            </div>
            <div class="dg-bonus-skills-header">
                <span class="dg-picks-counter">Picks used: <strong>{{bonusSkills.picksUsed}}</strong> / 8</span>
            </div>
            <div class="dg-bonus-slots">
                {{#each bonusSkills.slots}}
                <div class="dg-bonus-slot-row">
                    <label class="dg-bonus-slot-label">Pick {{inc index}}</label>
                    <select name="bonusSlot.{{index}}" class="dg-bonus-slot-select">
                        <option value="">— None —</option>
                        {{#if ../bonusSkills.profSlotOptions}}
                        <optgroup label="Your Profession Specialties">
                            {{#each ../bonusSkills.profSlotOptions}}
                            <option value="{{key}}" {{#if (eq key ../key)}}selected{{/if}}>{{label}}</option>
                            {{/each}}
                        </optgroup>
                        {{/if}}
                        {{#each ../bonusSkills.options}}
                        <option value="{{key}}" {{#if (eq key ../key)}}selected{{/if}}>{{label}}</option>
                        {{/each}}
                    </select>
                    <input type="text" name="bonusCustom.{{index}}" value="{{customLabel}}"
                        placeholder="Specialty name…" class="dg-bonus-custom-input" />
                </div>
                {{/each}}
            </div>
            <details class="dg-skills-ref-details">
                <summary>Skills Reference</summary>
                <div class="dg-skills-ref-cols">
                    {{#each bonusSkills.skillsCols}}
                    <table class="dg-skills-ref-table">
                        <thead>
                            <tr>
                                <th>Skill</th>
                                <th class="dg-num">Base</th>
                                <th class="dg-num">Boost</th>
                                <th class="dg-num">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            {{#each this}}
                            <tr class="dg-skills-ref-row{{#if boosted}} dg-skill-boosted{{/if}}{{#if isCustom}} dg-skill-custom{{/if}}" data-key="{{key}}"
                                data-base="{{base}}">
                                <td>{{label}}</td>
                                <td class="dg-num">{{base}}</td>
                                <td class="dg-num dg-skill-ref-boost">{{#if boosted}}+{{boostAmount}}{{/if}}</td>
                                <td class="dg-num dg-skill-ref-value">{{effective}}</td>
                            </tr>
                            {{/each}}
                        </tbody>
                    </table>
                    {{/each}}
                </div>
            </details>
            {{/if}}
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: bonds
        ================================================================ --}}
        {{#if (eq step "bonds")}}
        <div class="dg-step dg-step-bonds">
            <h2>Bonds</h2>

            <details class="dg-tips">
                <summary>Tips</summary>
                <p>Profession determines how many Bonds your Agent gets. Each Bond should have a name and specify the
                    relationship — <em>"Ex-husband, Taylor"</em> or <em>"Special Agent Waite, frequent FBI
                        partner."</em>
                    Each Bond starts with a score equal to your Agent's CHA.</p>
                <ul class="dg-tips-list">
                    <li>» Spouse or ex-spouse</li>
                    <li>» Son or daughter</li>
                    <li>» Favored parent or grandparent</li>
                    <li>» Best friend</li>
                    <li>» Long-time coworker or partner</li>
                    <li>» Psychologist or therapist</li>
                    <li>» Fellow survivors of a shared trauma</li>
                </ul>
                <p>Use the <strong>💡 suggestion pool</strong> dropdown to filter the random suggestion by relationship
                    type — Friends &amp; Family, Delta Green operatives, Underworld contacts, LGBTQ+ community, or
                    PISCES (British Intelligence).</p>
            </details>

            <p class="dg-hint">
                Your profession permits <strong>{{bondLimit}}</strong> bond(s).
                Bonds start at your CHA score ({{stats.cha}}).
            </p>
            <div class="dg-bond-dataset-row">
                <label>💡 Suggestion pool:
                    <select name="bondDataset" class="dg-bond-dataset-select">
                        {{#each bondDatasets}}
                        <option value="{{key}}" {{#if (eq key ../bondDataset)}}selected{{/if}}>{{label}}</option>
                        {{/each}}
                    </select>
                </label>
            </div>
            {{#each bonds}}
            <div class="dg-bond-block">
                <div class="dg-bond-row">
                    <span class="dg-bond-num">{{inc @index}}.</span>
                    <input type="text" name="bonds.{{@index}}.name" value="{{name}}" placeholder="Bond name…"
                        class="dg-bond-name" />
                    <label>Score</label>
                    <input type="number" name="bonds.{{@index}}.score" value="{{score}}" min="1" max="99"
                        class="dg-bond-score" />
                    <button type="button" data-action="suggestBond" data-index="{{@index}}" class="dg-btn-small"
                        title="Suggest a bond">💡</button>
                    <button type="button" data-action="removeBond" data-index="{{@index}}"
                        class="dg-btn-small dg-btn-danger" title="Remove">✕</button>
                </div>
                <div class="dg-bond-relationship-row">
                    <input type="text" name="bonds.{{@index}}.relationship" value="{{relationship}}"
                        placeholder="Relationship (e.g. Ex-wife, FBI partner…)" class="dg-bond-relationship-input" />
                </div>
                {{#if description}}
                <div class="dg-bond-details">
                    <p class="dg-bond-description">{{description}}</p>
                </div>
                {{/if}}
            </div>
            {{/each}}
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: biography
        ================================================================ --}}
        {{#if (eq step "biography")}}
        <div class="dg-step dg-step-biography">
            <h2>Biography</h2>

            <details class="dg-tips">
                <summary>Tips</summary>
                <p>Fill in your Agent's personal details. Hit the <strong>🎲 Random Bio</strong> button to
                    auto-generate a name, employer, education, and description matched to the profession you chose.
                    You can always edit the result afterward.</p>
            </details>

            <div class="dg-bio-actions">
                <button type="button" data-action="randomBio" class="dg-btn-secondary">🎲 Random Bio</button>
                <button type="button" data-action="pickPortrait" class="dg-btn-secondary">🖼 Set Portrait</button>
            </div>

            <div class="dg-bio-grid">
                <label class="dg-bio-full-row">Agent Name
                    <input type="text" name="biography.name" value="{{biography.name}}"
                        placeholder="First and last name" />
                </label>
                <label>Profession / Job Title
                    <input type="text" name="biography.profession" value="{{biography.profession}}"
                        placeholder="e.g. FBI Special Agent" />
                </label>
                <label>Employer
                    <input type="text" name="biography.employer" value="{{biography.employer}}"
                        placeholder="e.g. Federal Bureau of Investigation" />
                </label>
                <label>Nationality
                    <input type="text" name="biography.nationality" value="{{biography.nationality}}"
                        placeholder="e.g. American" />
                </label>
                <label>Sex
                    <input type="text" name="biography.sex" value="{{biography.sex}}"
                        placeholder="e.g. Male / Female / Non-binary" />
                </label>
                <label>Age
                    <input type="text" name="biography.age" value="{{biography.age}}" placeholder="e.g. 34" />
                </label>
                <label>Education
                    <input type="text" name="biography.education" value="{{biography.education}}"
                        placeholder="e.g. BA Criminology, Quantico" />
                </label>
                <fieldset class="dg-bio-full-row dg-motivations-block">
                    <legend>Motivations (up to 5)</legend>
                    {{#each motivations}}
                    <input type="text" name="motivation.{{@index}}" value="{{this}}"
                        placeholder="e.g. Protect my family, Uncover the truth…" />
                    {{/each}}
                </fieldset>
            </div>
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: equipment
        ================================================================ --}}
        {{#if (eq step "equipment")}}
        <div class="dg-step dg-step-equipment">
            <h2>Equipment</h2>

            <details class="dg-tips">
                <summary>Tips</summary>
                <p>Browse and add items by category. Click <strong>+</strong> to include gear, or remove it with the
                    <strong>✕</strong> on each item card.
                </p>
                <p><strong>Operational Gear:</strong> Agents usually start an operation with duffel bags and footlockers
                    of equipment. No need to list everything in advance — assume the basics are covered.</p>
                <details class="dg-tips-inner">
                    <summary>Expense Categories</summary>
                    <ul class="dg-tips-list">
                        <li><span class="dg-exp-badge dg-exp-incidental">Incidental</span> (up to $150) — No tracking
                            needed. Meals, ammo, burner phones, shovels.</li>
                        <li><span class="dg-exp-badge dg-exp-standard">Standard</span> ($200–$800) — A pistol, same-day
                            plane ticket, or a week at a modest hotel.</li>
                        <li><span class="dg-exp-badge dg-exp-unusual">Unusual</span> ($1,000–$5,000) — A scoped rifle,
                            forged passport, powerful computer.</li>
                        <li><span class="dg-exp-badge dg-exp-major">Major</span> ($6,000–$30,000) — Heavy weapons,
                            professional forgery, a new vehicle.</li>
                        <li><span class="dg-exp-badge dg-exp-extreme">Extreme</span> ($36,000+) — Black-budget
                            territory. Handler's call entirely.</li>
                    </ul>
                </details>
            </details>

            <div class="dg-eq-loadout-btns">
                <span class="dg-eq-loadout-btns-label">Quick Loadouts:</span>
                <button type="button" data-action="loadLoadout" data-loadout="federal_agent"
                    class="dg-btn-secondary dg-eq-loadout-btn">🕵 Federal Agent</button>
                <button type="button" data-action="loadLoadout" data-loadout="police_officer"
                    class="dg-btn-secondary dg-eq-loadout-btn">🚓 Police Officer</button>
                <button type="button" data-action="loadLoadout" data-loadout="swat"
                    class="dg-btn-secondary dg-eq-loadout-btn">🛡 SWAT</button>
                <button type="button" data-action="loadLoadout" data-loadout="special_operator"
                    class="dg-btn-secondary dg-eq-loadout-btn">⚔ Special Operator</button>
            </div>

            <div class="dg-eq-layout">
                <div class="dg-eq-left">
                    <div class="dg-eq-search-row">
                        <input type="text" id="dg-eq-search" class="dg-eq-search-input" placeholder="Search catalog…" />
                        <span class="dg-eq-count"></span>
                    </div>
                    <div id="dg-eq-cat-tabs" class="dg-eq-cat-tabs"></div>
                    <div id="dg-eq-catalog" class="dg-eq-catalog"></div>
                </div>
                <div class="dg-eq-right">
                    <div class="dg-eq-loadout-header">
                        Loadout
                        {{#if equipmentCount}}<span class="dg-eq-loadout-badge">{{equipmentCount}}</span>{{/if}}
                    </div>
                    <div id="dg-eq-loadout" class="dg-eq-loadout"></div>
                    <div class="dg-eq-custom-row">
                        <input type="text" id="dg-eq-custom-input" class="dg-eq-custom-input"
                            placeholder="Custom item…" />
                        <button type="button" id="dg-eq-custom-add" class="dg-btn-secondary">+ Add</button>
                    </div>
                    <button type="button" data-action="clearEquipment" class="dg-btn-secondary dg-eq-clear-btn">✕ Clear
                        Loadout</button>
                </div>
            </div>
        </div>
        {{/if}}

        {{!-- ================================================================
        STEP: review
        ================================================================ --}}
        {{#if (eq step "review")}}
        <div class="dg-step dg-step-review">
            <h2>Review &amp; Confirm</h2>
            <p class="dg-hint">Verify your agent before committing changes to the actor sheet.</p>
            {{#unless review.hasBioName}}<p class="dg-warn">⚠ No agent name set — go back to Biography.</p>{{/unless}}

            <section class="dg-review-section">
                <h3><button type="button" data-action="jumpToStep" data-step="1" class="dg-review-jump-btn">Statistics
                        ✎</button></h3>
                <div class="dg-stats-grid dg-stats-readonly">
                    {{#each review.stats}}
                    <div class="dg-stat-block">
                        <span class="dg-stat-label">{{label}}</span>
                        <span class="dg-stat-value">{{value}}</span>
                        <span class="dg-x5">×5 = {{x5}}</span>
                    </div>
                    {{/each}}
                </div>
            </section>

            <section class="dg-review-section dg-review-derived">
                <h3>Derived Attributes</h3>
                <div class="dg-review-derived-grid">
                    <span>HP</span><strong>{{review.derived.hp}}</strong>
                    <span>WP</span><strong>{{review.derived.wp}}</strong>
                    <span>SAN</span><strong>{{review.derived.san}}</strong>
                    <span>BP</span><strong>{{review.derived.bp}}</strong>
                </div>
            </section>

            <section class="dg-review-section">
                <h3><button type="button" data-action="jumpToStep" data-step="2" class="dg-review-jump-btn">Profession
                        ✎</button></h3>
                <p>{{review.profession}}</p>
            </section>

            <section class="dg-review-section">
                <h3><button type="button" data-action="jumpToStep" data-step="3" class="dg-review-jump-btn">Key Skills
                        ✎</button></h3>
                <div class="dg-review-skills">
                    {{#each review.skills}}
                    <span class="dg-review-skill">{{label}}: <strong>{{value}}%</strong></span>
                    {{/each}}
                    {{#each review.specialtySkills}}
                    <span class="dg-review-skill dg-review-skill-specialty">{{label}}:
                        <strong>{{value}}%</strong></span>
                    {{/each}}
                    {{#if review.bonusAllocations.length}}
                    <span class="dg-review-bonus-divider">Bonus picks <button type="button" data-action="jumpToStep"
                            data-step="4" class="dg-review-jump-btn dg-review-jump-inline">✎</button></span>
                    {{#each review.bonusAllocations}}
                    <span class="dg-review-skill dg-review-skill-bonus">{{label}}: <strong>+{{total}}%</strong></span>
                    {{/each}}
                    {{/if}}
                </div>
            </section>

            <section class="dg-review-section">
                <h3><button type="button" data-action="jumpToStep" data-step="5" class="dg-review-jump-btn">Bonds
                        ✎</button></h3>
                {{#each review.bonds}}
                <div class="dg-review-bond">{{name}}{{#if relationship}} — {{relationship}}{{/if}} ({{score}})</div>
                {{/each}}
                {{#unless review.bonds}}
                <p class="dg-warn">No bonds defined.</p>
                {{/unless}}
            </section>

            <section class="dg-review-section">
                <h3><button type="button" data-action="jumpToStep" data-step="6" class="dg-review-jump-btn">Biography
                        ✎</button></h3>
                <div class="dg-review-bio-grid">
                    {{#each review.biography}}
                    <span class="dg-review-bio-key">{{label}}</span>
                    <span class="dg-review-bio-val">{{value}}</span>
                    {{/each}}
                </div>
            </section>

            {{#if review.motivations.length}}
            <section class="dg-review-section">
                <h3><button type="button" data-action="jumpToStep" data-step="6" class="dg-review-jump-btn">Motivations
                        ✎</button></h3>
                <ul class="dg-review-motivations">
                    {{#each review.motivations}}
                    <li>{{this}}</li>
                    {{/each}}
                </ul>
            </section>
            {{/if}}

            {{#if review.equipment.length}}
            <section class="dg-review-section">
                <h3><button type="button" data-action="jumpToStep" data-step="7" class="dg-review-jump-btn">Equipment
                        ({{review.equipment.length}} items) ✎</button></h3>
                <div class="dg-review-equipment">
                    {{#each review.equipment}}
                    <span class="dg-review-eq-item">{{this}}</span>
                    {{/each}}
                </div>
            </section>
            {{/if}}
        </div>
        {{/if}}

    </form>{{!-- .dg-wizard-form --}}

    {{!-- Navigation --}}
    <div class="dg-wizard-nav">
        {{#unless isFirst}}
        <button type="button" data-action="prevStep" class="dg-btn-secondary">← Back</button>
        {{/unless}}
        <span class="dg-nav-spacer"></span>
        {{#if isLast}}
        <button type="button" data-action="finish" class="dg-btn-primary dg-btn-finish">✔ Apply to Sheet</button>
        {{else}}
        <button type="button" data-action="nextStep" class="dg-btn-primary">Next →</button>
        {{/if}}
    </div>

</div>{{!-- .dg-wizard-wrapper --}}